---
import Base from '../layouts/Base.astro';
import Eyebrow from '../components/Eyebrow.astro';
import WindField from '../components/WindField.astro';
import { SITE } from '../data/site';

const STEPS = [
  {
    num: '01',
    title: 'We reply',
    desc: 'Within two business days, from a person — not a funnel.',
  },
  {
    num: '02',
    title: 'Scoping call',
    desc: 'Thirty minutes on the problem, the constraints, and whether we’re the right team. If we’re not, we’ll say so.',
  },
  {
    num: '03',
    title: 'Discovery sprint',
    desc: 'If there’s a fit: framing, feasibility, and a costed plan in 2–4 weeks.',
  },
];
---

<Base
  title="Contact"
  description="Tell us what you’re trying to ship. Vaiyu Solutions — AI from architecture to production for regulated industries."
>
  <!-- Page hero -->
  <section class="relative overflow-hidden">
    <WindField class="text-ink" />
    <div class="relative mx-auto max-w-6xl px-5 pb-16 pt-20 md:pb-20 md:pt-28">
      <Eyebrow label="Contact" class="reveal" />
      <h1 class="h-display mt-5 max-w-3xl text-4xl md:text-6xl reveal reveal-2">
        Tell us what you’re trying to ship.
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-soft reveal reveal-3">
        One email starts it.
      </p>
      <a
        href={`mailto:${SITE.email}`}
        class="link-ink mt-10 inline-block break-all font-display text-2xl sm:text-3xl md:text-5xl reveal reveal-4"
      >
        {SITE.emailDisplay}
      </a>
      <p class="mt-8 font-mono text-xs text-slate reveal reveal-5">
        Based in {SITE.location} — working with teams worldwide.
      </p>
    </div>
  </section>

  <!-- What happens next -->
  <section class="border-t border-ink/10 bg-cream">
    <div class="mx-auto max-w-6xl px-5 py-16 md:py-20">
      <Eyebrow num="01" label="What happens next" />
      <div class="mt-10 grid gap-x-10 gap-y-10 md:grid-cols-3">
        {
          STEPS.map((s) => (
            <div class="border-t-2 border-ink/80 pt-5">
              <p class="font-mono text-[11px] text-slate">{s.num}</p>
              <h2 class="font-display mt-3 text-2xl">{s.title}</h2>
              <p class="mt-3 leading-relaxed text-ink-soft">{s.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Elsewhere -->
  <section class="border-t border-ink/10">
    <div class="mx-auto max-w-6xl px-5 py-16 md:py-20">
      <Eyebrow num="02" label="Elsewhere" />
      <ul class="mt-8 divide-y divide-ink/10 border-y border-ink/10 max-w-xl">
        <li>
          <a href={SITE.linkedin} rel="noopener" class="group flex items-baseline justify-between py-4">
            <span class="font-display text-xl transition-colors group-hover:text-saffron">LinkedIn</span>
            <span class="label-mono text-slate">vaiyu-solutions ↗</span>
          </a>
        </li>
        <li>
          <a href={SITE.github} rel="noopener" class="group flex items-baseline justify-between py-4">
            <span class="font-display text-xl transition-colors group-hover:text-saffron">GitHub</span>
            <span class="label-mono text-slate">Vaiyu-Solutions ↗</span>
          </a>
        </li>
      </ul>
    </div>
  </section>
</Base>
