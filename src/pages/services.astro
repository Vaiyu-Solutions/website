---
import Base from '../layouts/Base.astro';
import Eyebrow from '../components/Eyebrow.astro';
import CTABand from '../components/CTABand.astro';
import WindField from '../components/WindField.astro';
import { SERVICES, MODELS } from '../data/site';
---

<Base
  title="Services"
  description="Discovery sprints, data engineering, model development, MLOps, governance, and fractional AI leadership — six services that take AI from mandate to production."
>
  <!-- Page hero -->
  <section class="relative overflow-hidden">
    <WindField class="text-ink" />
    <div class="relative mx-auto max-w-6xl px-5 pb-14 pt-20 md:pt-24">
      <Eyebrow label="Services" class="reveal" />
      <h1 class="h-display mt-5 max-w-3xl text-4xl md:text-6xl reveal reveal-2">
        From mandate to production.
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-soft reveal reveal-3">
        Six services, one standard: systems that survive contact with auditors, regulators, and real
        users.
      </p>
    </div>
  </section>

  <!-- Service detail blocks -->
  {
    SERVICES.map((s) => (
      <section id={s.slug} class="scroll-mt-20 border-t border-ink/10">
        <div class="relative mx-auto grid max-w-6xl gap-x-12 gap-y-8 px-5 py-16 md:py-20 lg:grid-cols-12">
          <span class="ghost-num" aria-hidden="true">
            {s.num}
          </span>
          <div class="lg:col-span-5">
            <p class="font-mono text-[11px] text-slate">{s.num}</p>
            <h2 class="h-display mt-3 text-3xl md:text-4xl">{s.title}</h2>
            <p class="mt-4 leading-relaxed text-ink-soft">{s.tag}</p>
            <p class="mt-6 font-display text-lg italic text-saffron">{s.get}</p>
          </div>
          <div class="lg:col-span-7">
            <p class="label-mono text-slate">What we do</p>
            <ul class="mt-4 divide-y divide-ink/10 border-y border-ink/10">
              {s.bullets.map((b) => (
                <li class="py-3.5 text-[0.97rem] leading-relaxed">
                  {b.text}
                  {b.fn && (
                    <sup class="fn">
                      <a href={`#fn-${b.fn}`} aria-label={`Footnote ${b.fn}`}>
                        {b.fn}
                      </a>
                    </sup>
                  )}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>
    ))
  }

  <!-- Engagement models -->
  <section class="border-t border-ink/10 bg-paper">
    <div class="mx-auto max-w-6xl px-5 py-20 md:py-24">
      <Eyebrow num="07" label="How we engage" />
      <h2 class="h-display mt-4 max-w-2xl text-4xl md:text-5xl">
        Start small. Scale by evidence.
      </h2>
      <p class="mt-5 max-w-xl leading-relaxed text-ink-soft">
        Every engagement is structured so you can judge the work before you extend it.
      </p>
      <div class="mt-12 grid gap-x-10 gap-y-10 sm:grid-cols-2 lg:grid-cols-4">
        {
          MODELS.map((m) => (
            <div class="group border-t-2 border-ink/80 pt-5 transition duration-200 hover:-translate-y-1 hover:border-saffron">
              <p class="font-mono text-[11px] text-slate transition-colors group-hover:text-saffron">{m.num}</p>
              <h3 class="font-display mt-3 text-xl transition-colors group-hover:text-saffron">{m.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-ink-soft">{m.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CTABand />

  <!-- Footnotes -->
  <section aria-label="Sources and attribution" class="mx-auto max-w-6xl px-5 py-12">
    <p class="label-mono text-slate">Sources & attribution</p>
    <ol class="mt-4 max-w-3xl space-y-2 font-mono text-xs leading-relaxed text-slate">
      <li id="fn-a">
        a — The “data as IP” approach our founder led at Indiana University contributed to a $3.5M
        NIH/NCI award.
      </li>
      <li id="fn-b">
        b — Vaiyu client engagements: pre-training optimization with model accuracy maintained or
        improved.
      </li>
      <li id="fn-c">
        c — Founder track record at Indiana University, optimizing inference for clinical research
        environments.
      </li>
    </ol>
  </section>
</Base>
