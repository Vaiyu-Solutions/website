---
import { NAV } from '../data/site';

const path = Astro.url.pathname;
const norm = (p: string) => p.replace(/\/+$/, '') || '/';
const isActive = (href: string) => norm(path) === norm(href);
---

<header class="border-b border-ink/10 bg-paper">
  <div class="mx-auto flex max-w-6xl flex-wrap items-baseline justify-between gap-x-8 gap-y-3 px-5 py-5">
    <a href="/" class="flex items-center">
      <img src="/img/logo_full.png" alt="Vaiyu Solutions" class="h-9 w-auto" />
    </a>
    <nav aria-label="Main">
      <ul class="flex flex-wrap items-baseline gap-x-6 gap-y-2">
        {
          NAV.map((l) => (
            <li>
              <a
                href={l.href}
                aria-current={isActive(l.href) ? 'page' : undefined}
                class:list={[
                  'label-mono transition-colors hover:text-saffron',
                  isActive(l.href) ? 'text-saffron' : 'text-ink-soft',
                ]}
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
